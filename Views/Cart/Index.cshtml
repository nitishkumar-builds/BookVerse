@model BookVerse.Models.ViewModels.ShoppingCartVM

@{
    ViewData["Title"] = "Shopping Cart";
}

<style>
    :root {
        --ink:     #1a1a2e;
        --muted:   #64748b;
        --border:  #e2e8f0;
        --accent:  #6366f1;
        --accent2: #8b5cf6;
        --danger:  #ef4444;
        --surface: #f8fafc;
        --white:   #ffffff;
        --radius:  12px;
        --shadow:  0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.06);
    }

    body { background: var(--surface); color: var(--ink); }

    .cart-page { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

    .page-title {
        font-size: 1.75rem;
        font-weight: 700;
        letter-spacing: -.5px;
        margin-bottom: .25rem;
    }
    .page-sub { color: var(--muted); font-size: .9rem; margin-bottom: 2rem; }

    /* ── Layout ── */
    .cart-layout { display: grid; grid-template-columns: 1fr 340px; gap: 1.5rem; align-items: start; }
    @@media (max-width: 860px) { .cart-layout { grid-template-columns: 1fr; } }

    /* ── Cart Items ── */
    .cart-items-card {
        background: var(--white);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }
    .cart-items-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border);
        font-weight: 600;
        font-size: .85rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--muted);
        display: grid;
        grid-template-columns: 1fr 120px 140px 80px;
        gap: 1rem;
    }
    @@media (max-width: 640px) { .cart-items-header { display: none; } }

    .cart-item {
        display: grid;
        grid-template-columns: 1fr 120px 140px 80px;
        gap: 1rem;
        align-items: center;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border);
        transition: background .15s;
    }
    .cart-item:last-child { border-bottom: none; }
    .cart-item:hover { background: #fafbff; }
    @@media (max-width: 640px) {
        .cart-item { grid-template-columns: 1fr; gap: .75rem; }
    }

    .item-info { display: flex; gap: 1rem; align-items: center; }
    .item-thumb {
        width: 60px; height: 80px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid var(--border);
        flex-shrink: 0;
        background: var(--surface);
    }
    .item-thumb-placeholder {
        width: 60px; height: 80px;
        border-radius: 6px;
        background: linear-gradient(135deg, #e0e7ff, #ede9fe);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        font-size: 1.4rem;
    }
    .item-title { font-weight: 600; font-size: .95rem; margin-bottom: .2rem; }
    .item-author { font-size: .82rem; color: var(--muted); }
    .item-isbn   { font-size: .78rem; color: var(--muted); margin-top: .15rem; }

    /* tier badge */
    .tier-badge {
        display: inline-block;
        font-size: .7rem;
        font-weight: 600;
        padding: .15em .5em;
        border-radius: 4px;
        background: #ede9fe;
        color: #6d28d9;
        margin-top: .3rem;
    }

    .item-price { font-weight: 600; font-size: 1rem; }

    /* quantity controls */
    .qty-control {
        display: flex; align-items: center; gap: .4rem;
    }
    .qty-btn {
        width: 30px; height: 30px;
        border-radius: 50%;
        border: 1.5px solid var(--border);
        background: var(--white);
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; font-weight: 700; color: var(--ink);
        transition: all .15s;
        text-decoration: none;
    }
    .qty-btn:hover { border-color: var(--accent); color: var(--accent); background: #f0f0ff; }
    .qty-num { min-width: 28px; text-align: center; font-weight: 600; font-size: .95rem; }

    .remove-btn {
        background: none; border: none; cursor: pointer;
        color: var(--muted); font-size: .82rem;
        padding: .3rem .5rem;
        border-radius: 6px;
        transition: all .15s;
        text-decoration: none;
        display: inline-flex; align-items: center; gap: .3rem;
        white-space: nowrap;
    }
    .remove-btn:hover { color: var(--danger); background: #fff1f2; }

    /* ── Order Summary Card ── */
    .summary-card {
        background: var(--white);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 1.5rem;
        position: sticky;
        top: 80px;
    }
    .summary-title {
        font-size: 1rem; font-weight: 700;
        margin-bottom: 1.25rem;
        padding-bottom: .75rem;
        border-bottom: 1px solid var(--border);
    }
    .summary-row {
        display: flex; justify-content: space-between;
        align-items: center;
        font-size: .9rem;
        margin-bottom: .6rem;
        color: var(--muted);
    }
    .summary-row.total {
        color: var(--ink);
        font-size: 1.1rem;
        font-weight: 700;
        border-top: 1px solid var(--border);
        padding-top: .75rem;
        margin-top: .5rem;
    }
    .checkout-btn {
        display: block; width: 100%;
        padding: .85rem;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        color: var(--white);
        text-align: center;
        border-radius: 8px;
        font-weight: 600;
        font-size: .95rem;
        text-decoration: none;
        margin-top: 1.25rem;
        transition: opacity .15s, transform .1s;
        border: none; cursor: pointer;
    }
    .checkout-btn:hover { opacity: .9; transform: translateY(-1px); color: var(--white); }

    .continue-link {
        display: block; text-align: center;
        font-size: .82rem; color: var(--muted);
        margin-top: .75rem; text-decoration: none;
    }
    .continue-link:hover { color: var(--accent); }

    /* ── Empty State ── */
    .empty-cart {
        background: var(--white);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 4rem 2rem;
        text-align: center;
    }
    .empty-icon { font-size: 3.5rem; margin-bottom: 1rem; }
    .empty-title { font-size: 1.2rem; font-weight: 700; margin-bottom: .5rem; }
    .empty-sub { color: var(--muted); font-size: .9rem; margin-bottom: 1.5rem; }
    .browse-btn {
        display: inline-block;
        padding: .7rem 1.5rem;
        background: var(--accent);
        color: var(--white);
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        font-size: .9rem;
        transition: opacity .15s;
    }
    .browse-btn:hover { opacity: .85; color: var(--white); }
</style>

<div class="cart-page">
    <h1 class="page-title">Your Cart</h1>

    @if (!Model.ShoppingCartList.Any())
    {
        <div class="empty-cart">
            <div class="empty-icon">🛒</div>
            <div class="empty-title">Your cart is empty</div>
            <div class="empty-sub">Looks like you haven't added anything yet.</div>
            <a asp-controller="Products" asp-action="Index" class="browse-btn">Browse Books</a>
        </div>
    }
    else
    {
        <p class="page-sub">@Model.ShoppingCartList.Count() item(s) in your cart</p>

        <div class="cart-layout">
            <!-- Cart Items -->
            <div class="cart-items-card">
                <div class="cart-items-header">
                    <span>Book</span>
                    <span>Unit Price</span>
                    <span>Quantity</span>
                    <span>Remove</span>
                </div>

                @foreach (var item in Model.ShoppingCartList)
                {
                    <div class="cart-item">
                        <!-- Book Info -->
                        <div class="item-info">
                            @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                            {
                                <img src="@item.Product.ImageUrl" alt="@item.Product.Title" class="item-thumb" />
                            }
                            else
                            {
                                <div class="item-thumb-placeholder">📖</div>
                            }
                            <div>
                                <div class="item-title">@item.Product.Title</div>
                                <div class="item-author">@item.Product.Author</div>
                                <div class="item-isbn">ISBN: @item.Product.ISBN</div>
                                @{
                                    string tierLabel = item.Count switch
                                    {
                                        < 50  => "1–49 price",
                                        < 100 => "50+ price",
                                        _     => "100+ price"
                                    };
                                }
                                <span class="tier-badge">@tierLabel</span>
                            </div>
                        </div>

                        <!-- Unit Price -->
                        <div class="item-price">$@item.Price.ToString("F2")</div>

                        <!-- Quantity Controls -->
                        <div class="qty-control">
                            <a asp-action="Minus" asp-route-cartId="@item.Id" class="qty-btn">−</a>
                            <span class="qty-num">@item.Count</span>
                            <a asp-action="Plus"  asp-route-cartId="@item.Id" class="qty-btn">+</a>
                        </div>

                        <!-- Remove -->
                        <div>
                            <a asp-action="Remove" asp-route-cartId="@item.Id" class="remove-btn">
                                🗑 Remove
                            </a>
                        </div>
                    </div>
                }
            </div>

            <!-- Order Summary -->
            <div class="summary-card">
                <div class="summary-title">Order Summary</div>

                @foreach (var item in Model.ShoppingCartList)
                {
                    <div class="summary-row">
                        <span>@item.Product.Title (@item.Count×)</span>
                        <span>$@((item.Price * item.Count).ToString("F2"))</span>
                    </div>
                }

                <div class="summary-row total">
                    <span>Total</span>
                    <span>$@Model.OrderHeader.OrderTotal.ToString("F2")</span>
                </div>

                <a asp-action="Summary" class="checkout-btn">Proceed to Checkout →</a>
                <a asp-controller="Products" asp-action="Index" class="continue-link">← Continue shopping</a>
            </div>
        </div>
    }
</div>
