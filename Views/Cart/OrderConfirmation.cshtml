@model int

@{
    ViewData["Title"] = "Order Confirmed";
}

<style>
    :root {
        --ink:     #1a1a2e;
        --muted:   #64748b;
        --accent:  #6366f1;
        --accent2: #8b5cf6;
        --surface: #f8fafc;
        --white:   #ffffff;
        --radius:  16px;
        --shadow:  0 1px 3px rgba(0,0,0,.08), 0 8px 24px rgba(0,0,0,.07);
    }
    body { background: var(--surface); }

    .confirm-page {
        max-width: 560px; margin: 0 auto;
        padding: 4rem 1.5rem;
        text-align: center;
    }

    .check-ring {
        width: 80px; height: 80px; border-radius: 50%;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2rem;
        box-shadow: 0 8px 24px rgba(99,102,241,.35);
        animation: pop .4s cubic-bezier(.175,.885,.32,1.275);
    }
    @@keyframes pop {
        from { transform: scale(.5); opacity: 0; }
        to   { transform: scale(1);  opacity: 1; }
    }

    .confirm-title {
        font-size: 1.75rem; font-weight: 800;
        letter-spacing: -.5px;
        margin-bottom: .5rem;
        color: var(--ink);
    }
    .confirm-sub {
        color: var(--muted); font-size: .95rem; line-height: 1.6;
        margin-bottom: 2rem;
    }

    .order-ref {
        display: inline-block;
        background: white;
        border: 1.5px dashed #c7d2fe;
        border-radius: 8px;
        padding: .6rem 1.25rem;
        font-size: .85rem;
        color: var(--muted);
        margin-bottom: 2rem;
    }
    .order-ref strong { color: var(--accent); font-size: 1rem; }

    .actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    .btn-primary {
        padding: .75rem 1.5rem;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        color: white; border-radius: 8px;
        font-weight: 600; font-size: .9rem;
        text-decoration: none;
        transition: opacity .15s, transform .1s;
    }
    .btn-primary:hover { opacity: .9; transform: translateY(-1px); color: white; }

    .btn-secondary {
        padding: .75rem 1.5rem;
        background: white;
        color: var(--ink);
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        font-weight: 600; font-size: .9rem;
        text-decoration: none;
        transition: border-color .15s;
    }
    .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
</style>

<div class="confirm-page">
    <div class="check-ring">✓</div>

    <h1 class="confirm-title">Order Placed!</h1>
    <p class="confirm-sub">
        Thanks for your order. We'll get it packed and on its way shortly.<br>
        A confirmation will be sent to your email.
    </p>

    <div class="order-ref">
        Order <strong>#@Model</strong>
    </div>

    <div class="actions">
        <a asp-controller="Order" asp-action="Index" class="btn-primary">View My Orders</a>
        <a asp-controller="Home" asp-action="Index" class="btn-secondary">Keep Shopping</a>
    </div>
</div>
