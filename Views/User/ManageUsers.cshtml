@model List<BookVerse.Models.ViewModels.ManageUserVM>

@{
    ViewData["Title"] = "Manage Users";
}

<h1>Manage Users</h1>

<table class="table table-bordered table-striped">
    <thead>
    <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>City</th>
        <th>Role</th>
        <th>Status</th>
        <th>Action</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        bool isLocked = user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow;
        <tr>
            <td>@user.Name</td>
            <td>@user.Email</td>
            <td>@user.PhoneNumber</td>
            <td>@user.City</td>
            <td>@user.Role</td>
            <td>
                @if (isLocked)
                {
                    <span class="badge bg-danger">Locked</span>
                }
                else
                {
                    <span class="badge bg-success">Active</span>
                }
            </td>
            <td>
                <form asp-action="LockUnlock" asp-controller="User" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@user.Id" />
                    <button type="submit" class="btn btn-sm @(isLocked ? "btn-success" : "btn-danger")">
                        @(isLocked ? "Unlock" : "Lock")
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>